# Local secrets for Supabase Edge Functions
# Copy this file to supabase/functions/.env for local development.

BOT_TOKEN=
INTERNAL_SECRET=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
HF_API_TOKEN=

# Optional kb-ingestion tuning.
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
MAX_SWEEP_ITEMS=5
MAX_INGESTION_ATTEMPTS=3
STALE_PROCESSING_SECONDS=300
RETRY_AFTER_SECONDS=60
HEARTBEAT_INTERVAL_MS=15000
HF_EMBEDDING_BATCH_SIZE=8
HF_REQUEST_TIMEOUT_MS=30000
HF_FEATURE_EXTRACTION_URL=

# Optional ai-orchestrator retrieval tuning.
RETRIEVAL_MATCH_THRESHOLD=0.60
RETRIEVAL_MATCH_COUNT=5
RETRIEVAL_CANDIDATE_COUNT=50

# Optional ai-orchestrator LLM tuning.
HF_LLM_API_TOKEN=
LLM_MODEL=Qwen/Qwen2.5-7B-Instruct-1M:cheapest
LLM_ENDPOINT=https://router.huggingface.co/v1/chat/completions
LLM_REQUEST_TIMEOUT_MS=20000
LLM_MAX_PROVIDER_RETRIES=1
LLM_MAX_OUTPUT_TOKENS=500
LLM_TEMPERATURE=0.2
